generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  isActive  Boolean  @default(true)
  age       Int?
  phone     String?
  bio       String?
  createdAt DateTime @default(now())
  organizedEvents  Event[]          @relation("OrganizerEvents")
  staffAssignments StaffAssignment[]
  guestProfile     Guest?
  vendorProfile    Vendor?
  ownedVenues     Venue[]   @relation("VenueOwner")
  bookingRequests Booking[] @relation("OrganizerBookings")
  notifications   Notification[]
  bookingMessages BookingMessage[]
  sentDirectMessages     DirectMessage[] @relation("SentDirectMessages")
  receivedDirectMessages DirectMessage[] @relation("ReceivedDirectMessages")
}

enum Role {
  ORGANIZER
  STAFF
  VENDOR
  GUEST
  VENUE_OWNER
}

// ─── VENUES ──────────────────────────────────────────────────────────────────

model Venue {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  location    String
  city        String
  capacity    Int
  areaM2      Float?
  amenities   String?
  pricePerDay Float
  photos           String[]
  layoutDocuments  String[]
  availableDates   DateTime[]
  isActive    Boolean  @default(true)
  ownerId     Int
  createdAt   DateTime @default(now())

  // Relations
  owner    User      @relation("VenueOwner", fields: [ownerId], references: [id])
  bookings Booking[]
  layouts  Layout[]
}

// ─── BOOKINGS ────────────────────────────────────────────────────────────────

model Booking {
  id            Int           @id @default(autoincrement())
  venueId       Int
  organizerId   Int
  eventDate     DateTime
  status        BookingStatus @default(PENDING)
  notes         String?
  eventType     String?
  attendeeCount Int?
  decidedAt     DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  venue    Venue  @relation(fields: [venueId], references: [id])
  event    Event?
  organizer User  @relation("OrganizerBookings", fields: [organizerId], references: [id])
  messages BookingMessage[]
}

enum BookingStatus {
  PENDING
  APPROVED
  DECLINED
}

// ─── BOOKING MESSAGES ────────────────────────────────────────────────────────

model BookingMessage {
  id        Int      @id @default(autoincrement())
  bookingId Int
  senderId  Int
  content   String
  createdAt DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])
  sender  User    @relation(fields: [senderId], references: [id])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

// ─── EVENTS ──────────────────────────────────────────────────────────────────

model Event {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  date        DateTime
  time        String?
  dressCode   String?
  agenda      String?
  organizerId Int
  bookingId   Int?        @unique
  status      EventStatus @default(UPCOMING)
  createdAt   DateTime    @default(now())

  // Relations
  organizer        User              @relation("OrganizerEvents", fields: [organizerId], references: [id])
  booking          Booking?          @relation(fields: [bookingId], references: [id])
  tasks            Task[]
  budget           Budget?
  guests           Guest[]
  staffAssignments StaffAssignment[]
  vendorRequests   SourcingRequest[]
  feedbacks        Feedback[]
  layouts Layout[]
  rsvps            RSVP[]
  messages         Message[]
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

// ─── TASKS ───────────────────────────────────────────────────────────────────

model Task {
  id          Int        @id @default(autoincrement())
  eventId     Int
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  assigneeId  Int?
  createdAt   DateTime   @default(now())

  // Relations
  event    Event            @relation(fields: [eventId], references: [id])
  assignee StaffAssignment? @relation(fields: [assigneeId], references: [id])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─── STAFF ASSIGNMENTS ───────────────────────────────────────────────────────

model StaffAssignment {
  id         Int       @id @default(autoincrement())
  userId     Int
  eventId    Int
  specialty  String?
  employmentType String? // part-time, full-time

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])
  tasks  Task[]
}

// ─── BUDGET ──────────────────────────────────────────────────────────────────

model Budget {
  id            Int      @id @default(autoincrement())
  eventId       Int      @unique
  totalPlanned  Float
  createdAt     DateTime @default(now())

  // Relations
  event    Event          @relation(fields: [eventId], references: [id])
  items    BudgetItem[]
  expenses Expense[]
}

model BudgetItem {
  id          Int    @id @default(autoincrement())
  budgetId    Int
  category    String
  description String?
  plannedAmount Float

  // Relations
  budget Budget @relation(fields: [budgetId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  budgetId    Int
  category    String
  description String?
  amount      Float
  date        DateTime @default(now())

  // Relations
  budget Budget @relation(fields: [budgetId], references: [id])
}

// ─── VENDORS ─────────────────────────────────────────────────────────────────

model Vendor {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  companyName   String
  suppliesOffered String
  location      String
  contactEmail  String
  contactPhone  String?

  // Relations
  user     User              @relation(fields: [userId], references: [id])
  requests SourcingRequest[]
  invoices Invoice[]
}

// ─── SOURCING REQUESTS ───────────────────────────────────────────────────────

model SourcingRequest {
  id           Int                   @id @default(autoincrement())
  eventId      Int
  vendorId     Int
  items        String
  quantity     String?
  deliveryDate DateTime
  status       SourcingRequestStatus @default(PENDING)
  notes        String?
  createdAt    DateTime              @default(now())

  // Relations
  event    Event    @relation(fields: [eventId], references: [id])
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  delivery Delivery?
}

enum SourcingRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ─── DELIVERIES ──────────────────────────────────────────────────────────────

model Delivery {
  id               Int            @id @default(autoincrement())
  sourcingRequestId Int           @unique
  status           DeliveryStatus @default(PREPARING)
  updatedAt        DateTime       @updatedAt

  // Relations
  sourcingRequest SourcingRequest @relation(fields: [sourcingRequestId], references: [id])
}

enum DeliveryStatus {
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
}

// ─── INVOICES ────────────────────────────────────────────────────────────────

model Invoice {
  id           Int           @id @default(autoincrement())
  vendorId     Int
  amount       Float
  status       InvoiceStatus @default(PENDING_REVIEW)
  description  String?
  documentName String?
  documentData String?
  createdAt    DateTime      @default(now())

  // Relations
  vendor Vendor @relation(fields: [vendorId], references: [id])
}

enum InvoiceStatus {
  PENDING_REVIEW
  APPROVED
  PAID
}

// ─── GUESTS ──────────────────────────────────────────────────────────────────

model Guest {
  id                Int         @id @default(autoincrement())
  userId            Int         @unique
  dietaryPreference String?
  checkInStatus     Boolean     @default(false)

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  events   Event[]
  rsvps    RSVP[]
  messages Message[]
}

// ─── RSVP ────────────────────────────────────────────────────────────────────

model RSVP {
  id        Int        @id @default(autoincrement())
  guestId   Int
  eventId   Int
  status    RSVPStatus @default(PENDING)
  notes     String?
  checkedIn Boolean    @default(false)
  createdAt DateTime   @default(now())

  // Relations
  guest Guest @relation(fields: [guestId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}

enum RSVPStatus {
  ATTENDING
  NOT_ATTENDING
  MAYBE
  PENDING
}

// ─── FEEDBACK ────────────────────────────────────────────────────────────────

model Feedback {
  id           Int      @id @default(autoincrement())
  eventId      Int
  guestName    String
  overall      Int      // 1-5
  food         Int?
  venue        Int?
  organization Int?
  comments     String?
  createdAt    DateTime @default(now())

  // Relations
  event Event @relation(fields: [eventId], references: [id])
}

// ─── MESSAGES ────────────────────────────────────────────────────────────────

model Message {
  id               Int        @id @default(autoincrement())
  eventId          Int
  guestId          Int
  senderRole       SenderRole
  content          String
  seenByGuest      Boolean    @default(false)
  seenByOrganizer  Boolean    @default(false)
  sentAt           DateTime   @default(now())

  // Relations
  event Event @relation(fields: [eventId], references: [id])
  guest Guest @relation(fields: [guestId], references: [id])
}

enum SenderRole {
  ORGANIZER
  GUEST
}

// ─── DIRECT MESSAGES ─────────────────────────────────────────────────────────

model DirectMessage {
  id             Int      @id @default(autoincrement())
  senderId       Int
  receiverId     Int
  content        String
  seenByReceiver Boolean  @default(false)
  sentAt         DateTime @default(now())

  sender   User @relation("SentDirectMessages",     fields: [senderId],   references: [id])
  receiver User @relation("ReceivedDirectMessages", fields: [receiverId], references: [id])
}

model Layout {
  id        Int      @id @default(autoincrement())
  venueId   Int
  eventId   Int
  elements  Json
  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}